# Doxygen configuration for the supported owner-safe public API.
# Generated HTML is a local/CI artifact under docs/doxygen and is not committed.

PROJECT_NAME           = "LSM6DS3TR"
PROJECT_NUMBER         = "2.0.0"
PROJECT_BRIEF          = "LSM6DS3TR embedded library API documentation"
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English

MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 3
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = NO

SHOW_INCLUDE_FILES     = YES
INLINE_INFO            = YES
SOURCE_BROWSER         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
STRIP_CODE_COMMENTS    = NO

INPUT                  = README.md include LSM6DS3TR_imu_implementation_manual.md docs/DOCUMENTATION.md docs/IDF_PORT.md
FILE_PATTERNS          = *.h *.md
RECURSIVE              = YES
EXCLUDE                = include/LSM6DS3TR/CommandTable.h
EXAMPLE_PATH           = examples/01_basic_bringup_cli

USE_MDFILE_AS_MAINPAGE = README.md
FULL_PATH_NAMES        = NO
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_MEMBERS_CTORS_1ST = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = AUTO_LIGHT
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO

WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = FAIL_ON_WARNINGS
QUIET                  = YES
